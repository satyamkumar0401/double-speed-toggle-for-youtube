{
  "manifest_version": 3,
  "name": "Double Speed Toggle for YouTube",
  "version": "1.0.0",
  "description": "Adds a one-click 2x speed toggle button next to the YouTube player settings button.",
  "author": "Satyam Kumar",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [],

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}